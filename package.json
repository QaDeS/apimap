{
  "name": "universal-model-router",
  "version": "2.0.0",
  "description": "The ultimate AI model router - route requests between OpenAI, Anthropic, local models, and more",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "model-router": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "BUN_HOT=1 bun --hot src/server.ts --log-level debug",
    "dev:gui": "cd gui && bun run dev --host",
    "build:gui": "cd gui && bun run build",
    "start:all": "./start.sh",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "bench": "cd bench && ./run.sh quick",
    "bench:full": "cd bench && ./run.sh full",
    "bench:clean": "cd bench && ./run.sh clean",
    "bench:status": "cd bench && ./run.sh status",
    "bench:logs": "cd bench && ./run.sh logs",
    "bench:ci": "cd bench && CI=true ./run.sh quick",
    "docker:build": "docker build -t apimap:local .",
    "docker:run": "docker run -p 3000:3000 -p 3001:3001 --rm apimap:local"
  },
  "keywords": [
    "openai",
    "anthropic",
    "ollama",
    "llm",
    "router",
    "proxy",
    "gateway",
    "ai",
    "model"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  }
}
