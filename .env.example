# API Map - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your API keys
#   docker-compose up -d
#
# For custom ports:
#   APIMAP_PORT=8080 APIMAP_GUI_PORT=8081 docker-compose up -d
# ============================================================

# ------------------------------------------------------------------------------
# API Provider Keys (Optional - only add the ones you use)
# ------------------------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=sk-

# Anthropic
ANTHROPIC_API_KEY=sk-ant-

# Google Gemini
GOOGLE_API_KEY=

# Groq
GROQ_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Fireworks AI
FIREWORKS_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=

# Anyscale
ANYSCALE_API_KEY=

# AWS Bedrock (uses standard AWS SDK environment variables)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ------------------------------------------------------------------------------
# Port Configuration (Optional - defaults shown)
# ------------------------------------------------------------------------------

# External ports (what users access from the host)
# APIMAP_PORT=3000
# APIMAP_GUI_PORT=3001

# For reverse proxy scenarios (when external port differs from internal)
# APIMAP_EXTERNAL_PORT=3000
# APIMAP_EXTERNAL_GUI_PORT=3001

# ------------------------------------------------------------------------------
# Local LLM Configuration
# ------------------------------------------------------------------------------

# Local Ollama (Docker default connects to host's Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
