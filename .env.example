# API Map - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your API keys
#   docker-compose up -d
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-

# Anthropic
ANTHROPIC_API_KEY=sk-ant-

# Google Gemini
GOOGLE_API_KEY=

# Groq
GROQ_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Fireworks AI
FIREWORKS_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=

# Anyscale
ANYSCALE_API_KEY=

# Local Ollama (Docker default connects to host's Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
