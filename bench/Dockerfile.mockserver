# Mock LLM Server - Bun Implementation
FROM docker.io/oven/bun:1-alpine

WORKDIR /app

# Copy package files
COPY package.json bun.lockb* ./
RUN bun install --frozen-lockfile

# Copy source
COPY src/mock-server/ ./src/mock-server/

# Expose port
EXPOSE 9999

# Run
ENV MOCK_SERVER_PORT=9999
ENV MOCK_SERVER_HOST=0.0.0.0
ENV MOCK_LATENCY_MEAN_MS=100
ENV MOCK_LATENCY_STD_MS=20
ENV MOCK_TOKENS_PER_SEC=50
ENV MOCK_ERROR_RATE=0.01
ENV MOCK_MAX_CONTEXT=8192
ENV MOCK_STREAMING_ENABLED=true

CMD ["bun", "run", "src/mock-server/index.ts"]
