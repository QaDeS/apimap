{
  "name": "apibench",
  "version": "1.0.0",
  "description": "LiteLLM vs API Map vs Direct - Benchmark Suite (Bun)",
  "type": "module",
  "scripts": {
    "benchmark": "bun run src/benchmark/index.ts",
    "benchmark:quick": "bun run src/benchmark/index.ts --quick",
    "benchmark:direct-only": "bun run src/benchmark/index.ts --skip-targets litellm,apimap",
    "benchmark:no-errors": "bun run src/benchmark/index.ts --error-rate 0",
    "dev": "bun --watch run src/benchmark/index.ts",
    "build": "bun build src/benchmark/index.ts --outfile dist/benchmark --compile",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf logs/*.json results/*.json results/*.md reports/*.pdf",
    "report": "python3 visualize.py results/",
    "report:text": "python3 visualize.py --text-only results/",
    "stop": "docker-compose down -v"
  },
  "dependencies": {
    "elysia": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
