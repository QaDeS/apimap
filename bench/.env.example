# Benchmark Environment Configuration
#
# Copy this file to .env and customize for your setup:
#   cp .env.example .env

# =============================================================================
# API Map Configuration
# =============================================================================

# Use a published image instead of building from local source
# Set this to test against a specific release
# APIMAP_IMAGE=ghcr.io/qades/apimap:latest

# Port configuration (change if 3000/3001 are in use)
APIMAP_PORT=3000
APIMAP_GUI_PORT=3001
EXTERNAL_PORT=3000
EXTERNAL_GUI_PORT=3001

# =============================================================================
# Mock Server Configuration
# =============================================================================

# Base latency in milliseconds (0 = instant)
# Increase this to simulate slow LLM responses
MOCK_LATENCY_MEAN_MS=0
MOCK_LATENCY_STD_MS=0

# Token generation speed (tokens per second)
MOCK_TOKENS_PER_SEC=100

# Instant mode - no latency at all (true/false)
MOCK_INSTANT_MODE=false

# Error rate for chaos testing (0.0 - 1.0)
MOCK_ERROR_RATE=0.01

# Maximum context length in tokens
MOCK_MAX_CONTEXT=8192

# Enable streaming responses
MOCK_STREAMING_ENABLED=true

# =============================================================================
# Benchmark Configuration
# =============================================================================

# Warmup requests before timing (reduces cold-start effects)
BENCHMARK_WARMUP=5

# Benchmark scenarios: "concurrency:requests,concurrency:requests,..."
# Format: CONCURRENCY:NUM_REQUESTS pairs
# Examples:
#   "1:50"        - 1 concurrent, 50 requests
#   "1:50,10:100" - 1 concurrent 50 req, then 10 concurrent 100 req
BENCHMARK_SCENARIOS=1:50,10:100,50:200,100:300

# Request configuration
BENCHMARK_PROMPT_SIZE=100      # Characters in prompt
BENCHMARK_CONTEXT_SIZE=0       # Characters of context
BENCHMARK_MAX_TOKENS=50        # Max tokens in response

# =============================================================================
# Development Settings
# =============================================================================

# Set to "true" to wait for services to be healthy before running
WAIT_FOR_SERVICES=true

# Docker Compose project name
COMPOSE_PROJECT_NAME=apibench
